      "source": [
        "def factorial(n):\n",
        "   if n == 0 or n == 1:\n",
        "       return 1\n",
        "   else:\n",
        "       return n * factorial(n-1)\n",
        "\n",
        "try:\n",
        "   num = int(input(\"Enter a non-negative integer: \"))\n",
        "   if num < 0:\n",
        "       raise ValueError(\"Negative number not allowed\")\n",
        "   print(f\"Factorial of {num} is {factorial(num)}\")\n",
        "except ValueError as e:\n",
        "   print(\"Invalid input:\", e)"
